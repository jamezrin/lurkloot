---
const steps = [
  {
    n: "01",
    title: "Install & stay logged in",
    body: "Add it to your browser. It rides on the Twitch and Kick sessions you're already signed into — nothing to connect, no password to hand over.",
  },
  {
    n: "02",
    title: "Pick what to farm",
    body: "Enable each platform and let it auto-discover live campaigns. Prioritize the drops and games you care about, or just leave the defaults and walk away.",
  },
  {
    n: "03",
    title: "It watches & claims",
    body: "It quietly keeps your watch time counting in the background — no video tab required. It hops channels as campaigns end and claims every reward the moment it unlocks.",
  },
];
---

<section id="how" class="how act">
  <div class="wrap">
    <div class="how__head">
      <p class="eyebrow reveal">How it works</p>
      <h2 class="reveal-slow">Set it up once.<br /><span class="grad-text">Then forget it.</span></h2>
    </div>

    <ol class="how__steps">
      {steps.map((step) => (
        <li class="how__step reveal">
          <span class="how__n">{step.n}</span>
          <h3>{step.title}</h3>
          <p>{step.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .how__head h2 {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.98;
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    margin-top: 0.6rem;
  }
  .how__steps {
    list-style: none;
    padding: 0;
    margin: clamp(3rem, 7vw, 5.5rem) 0 0;
    display: grid;
    gap: clamp(2rem, 4vw, 3rem);
  }
  @media (min-width: 820px) {
    .how__steps {
      grid-template-columns: repeat(3, 1fr);
      gap: clamp(2rem, 4vw, 3.5rem);
    }
  }
  .how__step {
    position: relative;
    padding-top: 2.2rem;
    border-top: 1px solid var(--line-strong);
  }
  .how__n {
    position: absolute;
    top: 2rem;
    right: 0;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--faint);
  }
  .how__step h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.4rem, 2.4vw, 1.9rem);
    letter-spacing: -0.02em;
    margin-bottom: 0.7rem;
  }
  .how__step p {
    color: var(--muted);
    font-size: 1.02rem;
    max-width: 36ch;
  }
</style>
