---
const steps = [
  {
    n: "01",
    title: "Install & stay logged in",
    body: "Add it to Chrome. It rides on the Twitch and Kick sessions you're already signed into — nothing to connect, no password to hand over.",
  },
  {
    n: "02",
    title: "Pick what to farm",
    body: "Enable each platform, then let it auto-discover live campaigns. Prioritize the drops and games you care about, or just leave the defaults and walk away.",
  },
  {
    n: "03",
    title: "It watches & claims",
    body: "A background heartbeat keeps your watch time counting — no video tab required. It hops channels as campaigns end and claims every reward the moment it unlocks.",
  },
];
---

<section id="how" class="how">
  <div class="wrap">
    <div class="section-head reveal">
      <p class="eyebrow">Flight plan</p>
      <h2>Three steps, then hands off the controls.</h2>
      <p>
        Setup takes under a minute. After that, Stream Autopilot runs the whole
        loop — discover, watch, switch, claim — on its own.
      </p>
    </div>

    <ol class="how__steps">
      {steps.map((step) => (
        <li class="how__step reveal">
          <span class="how__n">{step.n}</span>
          <h3>{step.title}</h3>
          <p>{step.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .how {
    padding: clamp(3.5rem, 7vw, 6rem) 0;
  }
  .how__steps {
    list-style: none;
    padding: 0;
    margin: clamp(2.5rem, 5vw, 4rem) 0 0;
    display: grid;
    gap: 1.1rem;
    counter-reset: step;
  }
  @media (min-width: 820px) {
    .how__steps {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .how__step {
    position: relative;
    padding: clamp(1.6rem, 2.5vw, 2.1rem);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: linear-gradient(180deg, var(--ink-1), var(--ink-0));
    transition: border-color 0.3s var(--ease), transform 0.3s var(--ease);
  }
  .how__step:hover {
    border-color: var(--line-strong);
    transform: translateY(-3px);
  }
  .how__n {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    color: transparent;
    background: var(--signal-text);
    -webkit-background-clip: text;
    background-clip: text;
    display: inline-block;
    padding: 0.3em 0;
    border-bottom: 2px solid var(--purple);
    margin-bottom: 1.1rem;
  }
  .how__step h3 {
    font-size: 1.35rem;
    margin-bottom: 0.6rem;
  }
  .how__step p {
    color: var(--muted);
    font-size: 1rem;
    max-width: 34ch;
  }
</style>
