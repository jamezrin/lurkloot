---
// "Why you'll love it" — benefit-led taglines that sell the feeling. Copy is
// kept verbatim; presentation is cinematic, scroll-revealed, alternating.
type Perk = { n: string; head: string; sub: string };

const perks: Perk[] = [
  {
    n: "01",
    head: 'Always <span class="grad-text">first</span> to the drops.',
    sub: "The second a campaign goes live, it's already farming — you never miss a limited or timed reward again.",
  },
  {
    n: "02",
    head: 'Watch who you <span class="grad-text">love</span>. Farm the no-names.',
    sub: "Keep enjoying your favorite streamers while it quietly grinds drops on whoever's eligible in the background.",
  },
  {
    n: "03",
    head: 'Wake up to a <span class="grad-text">full inventory</span>.',
    sub: "Leave it running overnight and collect the whole haul by morning. Zero babysitting, zero missed claims.",
  },
  {
    n: "04",
    head: 'Watch when <span class="grad-text">YOU</span> want.',
    sub: "Your stream time is yours again. The grind happens whether you're watching or not.",
  },
];
---

<section id="why" class="why act">
  <div class="wrap">
    <p class="eyebrow reveal">Why you'll love it</p>
    <h2 class="why__lede reveal-slow">Drops, on your terms.</h2>
    <p class="why__deck reveal">Stop arranging your life around drop campaigns. Let them arrange themselves around you.</p>

    <ol class="why__list">
      {perks.map((p) => (
        <li class="why__item">
          <span class="why__n par" style="--depth:-0.5">{p.n}</span>
          <div class="why__body">
            <h3 class="reveal-slow" set:html={p.head}></h3>
            <p class="reveal">{p.sub}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .why__lede {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    margin: 0.6rem 0 1rem;
  }
  .why__deck {
    color: var(--muted);
    font-size: 1.15rem;
    max-width: 48ch;
  }

  .why__list {
    list-style: none;
    margin: clamp(3.5rem, 9vw, 7rem) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: clamp(3.5rem, 8vw, 6.5rem);
  }
  .why__item {
    display: grid;
    grid-template-columns: minmax(auto, 0.8fr) 1.4fr;
    gap: clamp(1rem, 4vw, 3rem);
    align-items: center;
  }
  /* alternate the big number to the opposite side for editorial rhythm */
  .why__item:nth-child(even) {
    grid-template-columns: 1.4fr minmax(auto, 0.8fr);
  }
  .why__item:nth-child(even) .why__n {
    order: 2;
    text-align: right;
  }
  .why__item:nth-child(even) .why__body {
    order: 1;
  }

  .why__n {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(4rem, 14vw, 11rem);
    line-height: 0.8;
    letter-spacing: -0.05em;
    color: transparent;
    -webkit-text-stroke: 1.5px var(--line-strong);
    opacity: 0.9;
    user-select: none;
  }
  .why__body h3 {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.02;
    font-size: clamp(1.9rem, 4.6vw, 3.4rem);
    margin-bottom: 0.8rem;
  }
  .why__body p {
    color: var(--muted);
    font-size: clamp(1.02rem, 1.6vw, 1.2rem);
    max-width: 44ch;
  }

  @media (max-width: 700px) {
    .why__item,
    .why__item:nth-child(even) {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
    .why__item:nth-child(even) .why__n {
      order: 0;
      text-align: left;
    }
    .why__item:nth-child(even) .why__body {
      order: 0;
    }
    .why__n {
      font-size: clamp(3rem, 18vw, 5rem);
    }
  }
</style>
