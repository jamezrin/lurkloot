---
import { LINKS } from "../consts";
---

<section id="top" class="hero">
  <div class="wrap hero__grid">
    <div class="hero__copy">
      <p class="eyebrow rise" style="animation-delay:.05s">Twitch &amp; Kick drop automation</p>

      <h1 class="rise" style="animation-delay:.12s">
        Farm Twitch &amp; Kick drops<br />
        on <span class="grad-text">autopilot</span>.
      </h1>

      <p class="hero__lede rise" style="animation-delay:.2s">
        Stream Autopilot earns your in-game drops for you — quietly, in your own
        browser. It watches the right channels, switches as campaigns end, and
        auto-claims every reward. No watching streams. No password. No servers.
      </p>

      <div class="hero__cta rise" style="animation-delay:.28s">
        <a class="btn btn--primary" href={LINKS.chrome} target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.66 5h9.78a4 4 0 0 1 3.46 2l.01.02L21.6 7.1A10 10 0 0 0 12 2Zm9.66 7H13.4a4 4 0 0 1 .6 2.06 4 4 0 0 1-.56 2.04L9.5 21.9A10 10 0 0 0 21.66 9ZM7.94 14.06 3.5 6.4A10 10 0 0 0 8.2 21.62L11.3 16A4 4 0 0 1 7.94 14.06ZM12 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6Z"/></svg>
          Add to Chrome — free
        </a>
        <a class="btn btn--ghost" href={LINKS.firefox} target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2Zm5.7 7.7c.2.7.3 1.5.3 2.3a6 6 0 0 1-11.3 2.8c.7.6 1.6 1 2.6 1a3.6 3.6 0 0 0 3.6-3.6c0-1.2-.8-2.2-1.9-2.2-.7 0-1.2.4-1.2 1 0 .4.2.6.5.9.2.2.3.4.3.7 0 .5-.4.9-1 .9-1 0-1.8-1-1.8-2.2 0-1.6 1.4-2.9 3.2-2.9 2 0 3.6 1.5 4 3.5Z"/></svg>
          Get for Firefox
        </a>
        <a class="hero__src" href={LINKS.github} target="_blank" rel="noopener">View source ↗</a>
      </div>

      <ul class="hero__trust rise" style="animation-delay:.36s">
        <li><span class="dot"></span> No password</li>
        <li><span class="dot"></span> Runs on your device</li>
        <li><span class="dot"></span> Open source</li>
        <li><span class="dot"></span> 10 languages</li>
      </ul>
    </div>

    <!-- Instrument cluster: the autopilot "flight deck" -->
    <aside class="deck rise" style="animation-delay:.34s" aria-label="Live farming status (illustrative)">
      <div class="deck__chrome">
        <span class="deck__led"></span>
        <span class="deck__title">autopilot · engaged</span>
        <span class="deck__ver">v1.0</span>
      </div>

      <div class="ring-wrap">
        <svg class="ring" viewBox="0 0 220 220" role="img" aria-label="Drop progress 72 percent">
          <defs>
            <linearGradient id="ringGrad" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="#a06bff" />
              <stop offset="0.55" stop-color="#7c3aed" />
              <stop offset="1" stop-color="#53fc18" />
            </linearGradient>
          </defs>
          <circle class="ring__track" cx="110" cy="110" r="92" />
          <circle class="ring__prog" cx="110" cy="110" r="92" />
          <g class="ring__ticks">
            {Array.from({ length: 60 }).map((_, i) => (
              <line
                x1="110"
                y1="14"
                x2="110"
                y2={i % 5 === 0 ? 24 : 19}
                transform={`rotate(${i * 6} 110 110)`}
              />
            ))}
          </g>
        </svg>
        <div class="ring__center">
          <span class="ring__pct">72<small>%</small></span>
          <span class="ring__label">campaign progress</span>
          <span class="ring__play" aria-hidden="true">▶</span>
        </div>
      </div>

      <div class="deck__feed" aria-hidden="true">
        <div class="feed__row">
          <span class="feed__tag tag--twitch">TWITCH</span>
          <span class="feed__msg">Watching <b>RivalsPilot</b> · Rust</span>
          <span class="feed__ok">+18m</span>
        </div>
        <div class="feed__row">
          <span class="feed__tag tag--kick">KICK</span>
          <span class="feed__msg">Switched channel · campaign ending</span>
          <span class="feed__ok">auto</span>
        </div>
        <div class="feed__row">
          <span class="feed__tag tag--claim">CLAIM</span>
          <span class="feed__msg">Reward claimed · <b>Signal Booster</b></span>
          <span class="feed__ok">✓</span>
        </div>
      </div>

      <div class="deck__stats">
        <div><span class="stat__n">2</span><span class="stat__l">platforms</span></div>
        <div><span class="stat__n">0</span><span class="stat__l">tabs needed</span></div>
        <div><span class="stat__n">∞</span><span class="stat__l">hands-off</span></div>
      </div>
    </aside>
  </div>
</section>

<style>
  .hero {
    padding: clamp(2.5rem, 7vw, 6rem) 0 clamp(3rem, 6vw, 5.5rem);
  }
  .hero__grid {
    display: grid;
    gap: clamp(2.5rem, 5vw, 4.5rem);
    align-items: center;
  }
  @media (min-width: 980px) {
    .hero__grid {
      grid-template-columns: 1.05fr 0.95fr;
    }
  }

  h1 {
    font-size: clamp(2.7rem, 7vw, 5.1rem);
    margin: 1.1rem 0 0;
  }
  .hero__lede {
    color: var(--muted);
    font-size: clamp(1.05rem, 1.6vw, 1.22rem);
    max-width: 36ch;
    margin-top: 1.4rem;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.85rem;
    margin-top: 2rem;
  }
  .hero__src {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--muted);
    transition: color 0.2s var(--ease);
  }
  .hero__src:hover {
    color: var(--lime);
  }
  .hero__trust {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.02em;
    color: var(--muted);
  }
  .hero__trust li {
    display: inline-flex;
    align-items: center;
    gap: 0.55em;
  }

  /* -------- instrument cluster -------- */
  .deck {
    position: relative;
    border: 1px solid var(--line-strong);
    border-radius: 22px;
    background:
      radial-gradient(120% 80% at 50% -10%, rgba(124, 58, 237, 0.18), transparent 60%),
      linear-gradient(180deg, var(--ink-1), var(--ink-0));
    padding: 1.1rem 1.1rem 1.3rem;
    box-shadow: 0 40px 90px -40px rgba(0, 0, 0, 0.9), inset 0 1px 0 rgba(255, 255, 255, 0.05);
    overflow: hidden;
  }
  .deck::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 26px 26px;
    mask-image: radial-gradient(circle at 50% 35%, #000, transparent 78%);
    pointer-events: none;
  }
  .deck__chrome {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--faint);
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--line);
  }
  .deck__led {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--lime);
    box-shadow: 0 0 12px var(--glow-lime);
    animation: blink 2.4s infinite;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }
  .deck__ver {
    margin-left: auto;
  }

  .ring-wrap {
    position: relative;
    width: min(280px, 70%);
    margin: 1.4rem auto 1rem;
    aspect-ratio: 1;
  }
  .ring {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
    filter: drop-shadow(0 0 18px rgba(124, 58, 237, 0.25));
  }
  .ring__track {
    fill: none;
    stroke: rgba(255, 255, 255, 0.08);
    stroke-width: 12;
  }
  .ring__prog {
    fill: none;
    stroke: url(#ringGrad);
    stroke-width: 12;
    stroke-linecap: round;
    stroke-dasharray: 578;
    stroke-dashoffset: 578;
    animation: fill 2s var(--ease) 0.5s forwards;
  }
  @keyframes fill {
    to {
      stroke-dashoffset: 162; /* ~72% of 578 */
    }
  }
  .ring__ticks line {
    stroke: rgba(255, 255, 255, 0.16);
    stroke-width: 1.5;
  }
  .ring__center {
    position: absolute;
    inset: 0;
    display: grid;
    place-content: center;
    text-align: center;
    gap: 0.1rem;
  }
  .ring__pct {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.6rem, 7vw, 3.4rem);
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .ring__pct small {
    font-size: 0.4em;
    color: var(--muted);
    margin-left: 0.1em;
  }
  .ring__label {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--faint);
  }
  .ring__play {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: var(--lime);
    opacity: 0.9;
  }

  .deck__feed {
    display: grid;
    gap: 0.4rem;
    margin-top: 0.4rem;
  }
  .feed__row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.82rem;
    padding: 0.5rem 0.7rem;
    border-radius: 11px;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid var(--line);
    animation: rise 0.6s var(--ease) both;
  }
  .feed__row:nth-child(1) { animation-delay: 0.9s; }
  .feed__row:nth-child(2) { animation-delay: 1.1s; }
  .feed__row:nth-child(3) { animation-delay: 1.3s; }
  .feed__tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    padding: 0.25em 0.5em;
    border-radius: 6px;
    font-weight: 600;
  }
  .tag--twitch { background: rgba(145, 71, 255, 0.18); color: #c4a7ff; }
  .tag--kick { background: rgba(83, 252, 24, 0.16); color: #9bff66; }
  .tag--claim { background: rgba(255, 255, 255, 0.08); color: var(--text); }
  .feed__msg { color: var(--muted); flex: 1; min-width: 0; }
  .feed__msg b { color: var(--text); font-weight: 600; }
  .feed__ok {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--lime);
  }

  .deck__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.6rem;
    margin-top: 0.9rem;
    text-align: center;
  }
  .deck__stats div {
    padding: 0.6rem 0.3rem;
    border-radius: 11px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.015);
  }
  .stat__n {
    display: block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1;
    background: var(--signal-text);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .stat__l {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--faint);
    margin-top: 0.3rem;
  }
</style>
