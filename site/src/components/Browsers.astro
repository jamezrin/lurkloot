---
// Full-color browser logos (Iconify `logos` set), inlined as raw SVG so the
// page stays zero-JS. Stream Autopilot installs from the Chrome Web Store and
// runs on every Chromium-based browser.
import chrome from "../assets/browsers/chrome.svg?raw";
import edge from "../assets/browsers/microsoft-edge.svg?raw";
import brave from "../assets/browsers/brave.svg?raw";
import opera from "../assets/browsers/opera.svg?raw";
import vivaldi from "../assets/browsers/vivaldi.svg?raw";
import arc from "../assets/browsers/arc.svg?raw";

const browsers = [
  { name: "Chrome", svg: chrome },
  { name: "Edge", svg: edge },
  { name: "Brave", svg: brave },
  { name: "Opera", svg: opera },
  { name: "Vivaldi", svg: vivaldi },
  { name: "Arc", svg: arc },
];
---

<section id="browsers" class="compat">
  <div class="wrap">
    <div class="section-head reveal">
      <p class="eyebrow">Works everywhere</p>
      <h2>One install. Every Chromium browser.</h2>
      <p>
        Stream Autopilot installs from the Chrome Web Store and runs on
        <b>every Chromium-based browser</b> — Chrome, Microsoft Edge, Brave, Opera,
        Vivaldi, Arc, and the rest. Same extension, same features, no separate build.
      </p>
    </div>

    <ul class="compat__row reveal">
      {browsers.map((b) => (
        <li class="bchip">
          <span class="bchip__logo" set:html={b.svg} aria-hidden="true"></span>
          <span class="bchip__name">{b.name}</span>
        </li>
      ))}
      <li class="bchip bchip--more">
        <span class="bchip__plus" aria-hidden="true">+</span>
        <span class="bchip__name">any Chromium browser</span>
      </li>
    </ul>
  </div>
</section>

<style>
  .compat {
    padding: clamp(2.5rem, 5vw, 4rem) 0;
  }
  .compat__row {
    list-style: none;
    padding: 0;
    margin: clamp(2rem, 4vw, 2.8rem) 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }
  .bchip {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.75rem 1.15rem 0.75rem 0.9rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: linear-gradient(180deg, var(--ink-1), var(--ink-0));
    transition: transform 0.25s var(--ease), border-color 0.25s var(--ease);
  }
  .bchip:hover {
    transform: translateY(-3px);
    border-color: var(--line-strong);
  }
  .bchip__logo {
    display: inline-flex;
    filter: saturate(1.05);
  }
  .bchip__logo :global(svg) {
    height: 1.85rem;
    width: auto;
    display: block;
  }
  .bchip__name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: -0.01em;
  }
  .bchip--more {
    background: transparent;
    border-style: dashed;
    color: var(--muted);
  }
  .bchip--more .bchip__name {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
  }
  .bchip__plus {
    display: grid;
    place-content: center;
    width: 1.85rem;
    height: 1.85rem;
    border-radius: 50%;
    background: var(--signal);
    color: #0a0612;
    font-weight: 700;
    font-size: 1.1rem;
    line-height: 1;
  }
</style>
