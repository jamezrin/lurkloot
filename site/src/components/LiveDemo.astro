---
import PopupDemo from "../popup-ui/PopupDemo.tsx";
---

<section id="demo" class="demo">
  <div class="wrap">
    <div class="section-head reveal">
      <p class="eyebrow">Try it yourself</p>
      <h2>Not a screenshot — the actual UI.</h2>
      <p>
        This is the real Stream Autopilot popup, running right here on demo data.
        Switch Twitch/Kick, open Settings, reorder campaigns, flip toggles —
        poke around. It's exactly what you get after installing.
      </p>
    </div>

    <div class="demo__stage reveal">
      <div class="demo__glow" aria-hidden="true"></div>
      <div class="demo__screen">
        <span class="demo__pill"><span class="dot"></span> live demo · mock data</span>
        <PopupDemo client:visible />
      </div>
    </div>
  </div>
</section>

<style>
  .demo {
    padding: clamp(3rem, 6vw, 5.5rem) 0;
    overflow: hidden;
  }
  .demo .section-head {
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }

  .demo__stage {
    position: relative;
    display: flex;
    justify-content: center;
  }
  .demo__glow {
    position: absolute;
    top: -8%;
    width: min(640px, 90%);
    height: 70%;
    background: radial-gradient(closest-side, rgba(124, 58, 237, 0.32), transparent 70%);
    filter: blur(40px);
    pointer-events: none;
  }

  .demo__screen {
    position: relative;
    width: 400px;
    /* the popup's <main> is 600px tall; reserve it so there's no layout jump
       before the island hydrates */
    min-height: 600px;
  }
  /* The popup host (shadow root) carries the extension's own border/shadow. */
  .demo__screen :global(.sa-popup-host) {
    display: block;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 50px 90px -50px rgba(0, 0, 0, 0.95);
  }

  .demo__pill {
    position: absolute;
    top: -1.1rem;
    right: 0.4rem;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    padding: 0.4em 0.7em;
    border-radius: 999px;
    border: 1px solid var(--line-strong);
    background: var(--ink-2);
    color: var(--muted);
  }

  /* keep the fixed-width popup from overflowing narrow viewports */
  @media (max-width: 460px) {
    .demo__stage {
      height: calc(600px * 0.82 + 1.2rem);
    }
    .demo__screen {
      transform: scale(0.82);
      transform-origin: top center;
    }
  }
</style>
