{
  "name": "@lurkloot/extension",
  "version": "1.4.0",
  "description": "Cross-browser Twitch and Kick drops farming WebExtension using visible muted tabs.",
  "type": "module",
  "private": true,
  "scripts": {
    "postinstall": "wxt prepare",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "kick:inspect": "node scripts/kick-inspect.mjs",
    "screenshot:store": "pnpm build && node scripts/capture-store-screenshot.mjs",
    "promo:store": "pnpm build && node scripts/capture-store-promo.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lurkloot/core": "workspace:*",
    "@lurkloot/locales": "workspace:*",
    "@lurkloot/popup-ui": "workspace:*",
    "@lurkloot/shared": "workspace:*",
    "@vitejs/plugin-react": "^5.0.0",
    "@wxt-dev/module-react": "^1.1.3",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "wxt": "^0.20.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/chrome": "^0.0.279",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.2",
    "vitest": "^4.0.0"
  }
}
