{
  "name": "@stream-autopilot/site",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Marketing landing page for the Stream Autopilot browser extension.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "cf:create": "wrangler pages project create stream-autopilot --production-branch=main",
    "cf:deploy": "astro build && wrangler pages deploy dist --project-name=stream-autopilot --branch=main --commit-dirty=true"
  },
  "dependencies": {
    "@astrojs/react": "^4.2.0",
    "@astrojs/sitemap": "^3.2.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/bricolage-grotesque": "^5.1.1",
    "@fontsource-variable/geist": "^5.1.0",
    "@fontsource-variable/geist-mono": "^5.1.1",
    "@stream-autopilot/popup-ui": "workspace:*",
    "@stream-autopilot/shared": "workspace:*",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^5.1.1",
    "framer-motion": "^12.40.0",
    "lenis": "^1.3.23",
    "lucide-react": "^0.468.0",
    "marked": "^18.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.1",
    "wrangler": "^4.99.0"
  }
}
