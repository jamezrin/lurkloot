{
  "name": "@lurkloot/site",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Marketing landing page for the Lurkloot browser extension.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "cf:create": "wrangler pages project create lurkloot --production-branch=main",
    "cf:deploy": "astro build && wrangler pages deploy dist --project-name=lurkloot --branch=main --commit-dirty=true"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.0",
    "@astrojs/sitemap": "^3.2.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/bricolage-grotesque": "^5.1.1",
    "@fontsource-variable/geist": "^5.1.0",
    "@fontsource-variable/geist-mono": "^5.1.1",
    "@lurkloot/popup-ui": "workspace:*",
    "@lurkloot/shared": "workspace:*",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^6.0.0",
    "framer-motion": "^12.40.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.0.0",
    "marked": "^18.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "vite": "^7.3.2",
    "wrangler": "^4.103.0"
  }
}
