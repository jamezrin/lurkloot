---
// Section order tells the story: hook (Hero, Why), show (How, the real demo),
// depth (Features), proof (Coverage: platforms + games), trust (Privacy, FAQ),
// close (CTA with the objection-buster strip).
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import Manifesto from "../components/Manifesto.astro";
import HowItWorks from "../components/HowItWorks.astro";
import LiveDemo from "../components/LiveDemo.astro";
import Features from "../components/Features.astro";
import Coverage from "../components/Coverage.astro";
import Privacy from "../components/Privacy.astro";
import Faq from "../components/Faq.astro";
import Cta from "../components/Cta.astro";
import Footer from "../components/Footer.astro";
---

<Base>
  <main>
    <Hero />
    <Manifesto />
    <HowItWorks />
    <LiveDemo />
    <Features />
    <Coverage />
    <Privacy />
    <Faq />
    <Cta />
  </main>
  <Footer />
</Base>
