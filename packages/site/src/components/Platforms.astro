---
const platforms = [
  {
    key: "twitch",
    name: "Twitch",
    blurb:
      "It finds the Twitch drops you can earn, keeps you on a channel that's actually dropping them, and claims every reward for you — channel points included.",
    points: ["Finds every drop you can earn", "Always on a dropping channel", "Claims drops + channel points"],
  },
  {
    key: "kick",
    name: "Kick",
    blurb:
      "Full Kick drops support, right in your browser. It follows live campaigns, picks the right channel for the reward you want, and claims it the moment it unlocks.",
    points: ["Follows live Kick campaigns", "Picks the right channel for you", "Claims rewards automatically"],
  },
];
---

<section id="platforms" class="plat act">
  <div class="wrap">
    <div class="plat__head">
      <p class="eyebrow reveal">Coverage</p>
      <h2 class="reveal-slow">Two platforms.<br />Every drop campaign.</h2>
      <p class="reveal">
        Farming <b>Rust</b> Twitch drops, <b>Valorant</b> rewards, or a Kick partner
        campaign — it speaks both platforms natively, no manual channel hunting.
      </p>
    </div>

    <div class="plat__grid">
      {platforms.map((p) => (
        <div class="reveal">
        <article class={`plat__card plat__card--${p.key}`} data-tilt="" data-tilt-max="5">
          <div class="plat__top">
            <span class={`plat__badge plat__badge--${p.key}`}>{p.name[0]}</span>
            <h3>{p.name}</h3>
            <span class="plat__status"><span class="dot"></span> supported</span>
          </div>
          <p>{p.blurb}</p>
          <ul>
            {p.points.map((pt) => <li>{pt}</li>)}
          </ul>
        </article>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .plat__head h2 {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.98;
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    margin: 0.6rem 0 1rem;
  }
  .plat__head p {
    color: var(--muted);
    font-size: 1.1rem;
    max-width: 52ch;
  }
  .plat__head b { color: var(--text); font-weight: 600; }

  .plat__grid {
    display: grid;
    gap: 1.2rem;
    margin-top: clamp(2.5rem, 6vw, 4rem);
  }
  @media (min-width: 760px) {
    .plat__grid { grid-template-columns: 1fr 1fr; }
  }
  .plat__card {
    height: 100%;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    padding: clamp(1.8rem, 3vw, 2.6rem);
    transition: transform 0.4s var(--ease), border-color 0.4s var(--ease);
  }
  .plat__card--twitch {
    background: radial-gradient(120% 130% at 0% 0%, rgba(145, 71, 255, 0.22), transparent 55%), var(--ink-0);
  }
  .plat__card--twitch:hover { border-color: rgba(145, 71, 255, 0.55); }
  .plat__card--kick {
    background: radial-gradient(120% 130% at 100% 0%, rgba(83, 252, 24, 0.16), transparent 55%), var(--ink-0);
  }
  .plat__card--kick:hover { border-color: rgba(83, 252, 24, 0.5); }

  .plat__top {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1.2rem;
  }
  .plat__badge {
    width: 46px;
    height: 46px;
    border-radius: 13px;
    display: grid;
    place-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.4rem;
  }
  .plat__badge--twitch { background: linear-gradient(135deg, #a06bff, #7c3aed); color: #fff; }
  .plat__badge--kick { background: linear-gradient(135deg, #7bfd49, #3fbf12); color: #07140a; }
  .plat__top h3 {
    flex: 1;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.7rem;
    letter-spacing: -0.02em;
  }
  .plat__status {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--muted);
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
  }
  .plat__card > p {
    color: var(--muted);
    font-size: 1.02rem;
  }
  .plat__card ul {
    list-style: none;
    padding: 0;
    margin: 1.3rem 0 0;
    display: grid;
    gap: 0.5rem;
  }
  .plat__card li {
    position: relative;
    padding-left: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text);
  }
  .plat__card li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--purple-soft);
  }
</style>
