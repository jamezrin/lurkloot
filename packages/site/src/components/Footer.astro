---
import { LINKS } from "../consts";
import logo from "../assets/logo-ring.svg";
const year = new Date().getFullYear();
---

<footer class="foot">
  <div class="wrap foot__inner">
    <div class="foot__brand">
      <a class="foot__logo" href="#top">
        <img src={logo.src} width="34" height="34" alt="Lurkloot" />
        <span>Lurkloot</span>
      </a>
      <p>Farm Twitch &amp; Kick drops on autopilot — free and private.</p>
      <div class="foot__social">
        <a href={LINKS.x} target="_blank" rel="noopener me" aria-label="Follow on X">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"/>
          </svg>
        </a>
        <a href={LINKS.github} target="_blank" rel="noopener me" aria-label="View on GitHub">
          <svg viewBox="0 0 24 24" width="19" height="19" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.34-5.47-5.95 0-1.31.47-2.39 1.24-3.23-.12-.31-.54-1.53.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.65.24 2.87.12 3.18.77.84 1.24 1.92 1.24 3.23 0 4.62-2.81 5.64-5.49 5.94.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 24 12.5C24 5.87 18.63.5 12 .5Z"/>
          </svg>
        </a>
      </div>
    </div>
    <nav class="foot__links" aria-label="Footer">
      <a href={LINKS.chrome} target="_blank" rel="noopener">Chrome Web Store</a>
      <a href={LINKS.github} target="_blank" rel="noopener">Source code</a>
      <a href={LINKS.changelog}>Changelog</a>
      <a href={LINKS.privacy}>Privacy Policy</a>
    </nav>
  </div>
  <div class="wrap foot__legal">
    <span>© {year} jamezrin</span>
    <span class="foot__disc">
      Not affiliated with, endorsed by, or sponsored by Twitch or Kick. All trademarks
      belong to their respective owners. Use at your own discretion.
    </span>
  </div>
</footer>

<style>
  .foot {
    border-top: 1px solid var(--line);
    padding: clamp(2.5rem, 5vw, 4rem) 0 2.5rem;
    background: linear-gradient(180deg, transparent, rgba(124, 58, 237, 0.05));
  }
  .foot__inner {
    display: grid;
    gap: 2rem;
  }
  @media (min-width: 720px) {
    .foot__inner {
      grid-template-columns: 1fr auto;
      align-items: start;
    }
  }
  .foot__logo {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
  }
  .foot__logo img { border-radius: 9px; }
  .foot__brand p {
    color: var(--muted);
    font-size: 0.92rem;
    margin-top: 0.8rem;
    max-width: 34ch;
  }
  .foot__social {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 1.1rem;
  }
  .foot__social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    color: var(--muted);
    border: 1px solid var(--line);
    background: var(--ink-1);
    transition: color 0.2s var(--ease), border-color 0.2s var(--ease), transform 0.2s var(--ease);
  }
  .foot__social a:hover {
    color: var(--lime);
    border-color: var(--line-strong);
    transform: translateY(-2px);
  }
  .foot__links {
    display: grid;
    gap: 0.7rem;
    font-size: 0.92rem;
    color: var(--muted);
  }
  @media (min-width: 480px) {
    .foot__links {
      grid-template-columns: 1fr 1fr;
      gap: 0.7rem 2.5rem;
    }
  }
  .foot__links a {
    transition: color 0.2s var(--ease);
  }
  .foot__links a:hover { color: var(--lime); }
  .foot__legal {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--faint);
  }
  .foot__disc {
    max-width: 70ch;
  }
</style>
