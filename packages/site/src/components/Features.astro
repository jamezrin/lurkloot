---
// Main features as cinematic alternating beats (text + a stylized visual that
// parallaxes). Followed by a compact "and more" row for breadth.
const more = [
  { t: "Watch Queue fallback", d: "Up to 20 backup channels keep you earning when no drops are live." },
  { t: "Game & category filters", d: "Farm everything, or pin just the games you care about." },
  { t: "Reward notifications", d: "Get pinged the moment a drop is claimable — or when you're all done." },
  { t: "Ten languages", d: "Fully localized UI. English or Spanish? You've got more options too." },
];
---

<section id="features" class="feat act">
  <div class="wrap">
    <div class="feat__head">
      <p class="eyebrow reveal">Under the hood</p>
      <h2 class="reveal-slow">More than a tab<br />that watches a stream.</h2>
    </div>

    <!-- Beat 1 — tabless -->
    <div class="beat">
      <div class="beat__copy reveal">
        <span class="kicker">Default · low-resource</span>
        <h3>Sips, doesn't chug.</h3>
        <p>
          Instead of pinning a video tab and burning bandwidth, it keeps your watch time
          counting quietly in the background. Drops tick up while your machine stays cool —
          and if progress ever stalls, it falls back to a muted tab so you never miss out.
        </p>
      </div>
      <div class="beat__lift reveal">
        <div class="beat__viz" data-tilt>
          <div class="viz-row"><span>Old way</span><i class="bar bar--heavy"><b style="width:88%"></b></i><em>heavy</em></div>
          <div class="viz-row"><span>Autopilot</span><i class="bar bar--light"><b style="width:14%"></b></i><em>~14%</em></div>
          <div class="viz-pulse"><s></s><s></s><s></s><s></s><s></s><em>watching</em></div>
        </div>
      </div>
    </div>

    <!-- Beat 2 — scheduling -->
    <div class="beat">
      <div class="beat__copy reveal">
        <span class="kicker">Smart scheduler</span>
        <h3>Farms the right thing first.</h3>
        <p>
          It tracks the exact channel dropping what you want and re-routes the instant a
          campaign ends. Drag to set your own order, or pick a strategy and let it decide.
        </p>
      </div>
      <div class="beat__lift reveal">
        <div class="beat__viz beat__viz--chips" data-tilt>
          <span class="chip chip--on">Ending soonest</span>
          <span class="chip">Lowest availability</span>
          <span class="chip">Priority list</span>
          <span class="chip chip--drag">⠿ drag to reorder</span>
        </div>
      </div>
    </div>

    <!-- Beat 3 — auto-claim -->
    <div class="beat">
      <div class="beat__copy reveal">
        <span class="kicker">Hands-off rewards</span>
        <h3>Claimed the instant it unlocks.</h3>
        <p>
          Every drop — and, if you want, Twitch channel points — is claimed for you
          automatically. You just open your inventory and find it already there.
        </p>
      </div>
      <div class="beat__lift reveal">
        <div class="beat__viz beat__viz--claims" data-tilt>
          <div class="claim"><span class="dot"></span> Signal Booster <em>claimed ✓</em></div>
          <div class="claim"><span class="dot"></span> Marathon Crate <em>claimed ✓</em></div>
          <div class="claim claim--pending"><span></span> Arena Skin <em>2h 16m</em></div>
        </div>
      </div>
    </div>

    <!-- Beat 4 — activity -->
    <div class="beat">
      <div class="beat__copy reveal">
        <span class="kicker">Total transparency</span>
        <h3>Always know what it's doing.</h3>
        <p>
          A real-time, filterable log records every decision — channel switches, claims,
          skips, retries. It's never a black box.
        </p>
      </div>
      <div class="beat__lift reveal">
        <div class="beat__viz beat__viz--log" data-tilt>
          <div class="logline"><i>14:02</i><b>INFO</b> Switched to RivalsPilot · Rust drops live</div>
          <div class="logline"><i>14:09</i><b class="ok">CLAIM</b> Reward unlocked &amp; claimed</div>
          <div class="logline"><i>14:18</i><b>INFO</b> Campaign ended · re-routing</div>
        </div>
      </div>
    </div>

    <ul class="feat__more">
      {more.map((m) => (
        <li class="reveal">
          <strong>{m.t}</strong>
          <span>{m.d}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .feat__head h2 {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.98;
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    margin-top: 0.6rem;
  }

  .beat {
    display: grid;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
    margin-top: clamp(4rem, 10vw, 8rem);
  }
  @media (min-width: 860px) {
    .beat {
      grid-template-columns: 1fr 1fr;
    }
    .beat:nth-child(even) .beat__copy {
      order: 2;
    }
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--purple-soft);
  }
  .beat__copy h3 {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1;
    font-size: clamp(2rem, 4.6vw, 3.6rem);
    margin: 0.8rem 0 1rem;
  }
  .beat__copy p {
    color: var(--muted);
    font-size: clamp(1.02rem, 1.6vw, 1.2rem);
    max-width: 42ch;
  }

  /* visuals */
  .beat__viz {
    border: 1px solid var(--line);
    border-radius: 22px;
    padding: clamp(1.6rem, 3vw, 2.4rem);
    background:
      radial-gradient(120% 90% at 100% 0%, rgba(124, 58, 237, 0.16), transparent 55%),
      linear-gradient(180deg, var(--ink-1), var(--ink-0));
    box-shadow: 0 40px 80px -50px rgba(0, 0, 0, 0.9);
    display: grid;
    gap: 1rem;
  }
  .viz-row {
    display: grid;
    grid-template-columns: 78px 1fr auto;
    align-items: center;
    gap: 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--muted);
  }
  .bar {
    height: 11px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    overflow: hidden;
  }
  .bar b {
    display: block;
    height: 100%;
    border-radius: 999px;
  }
  .bar--heavy b { background: linear-gradient(90deg, #ff7849, #ff3b6b); }
  .bar--light b { background: var(--signal); }
  .viz-pulse {
    display: flex;
    align-items: center;
    gap: 6px;
    padding-top: 0.8rem;
    border-top: 1px dashed var(--line);
  }
  .viz-pulse s {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--lime);
    opacity: 0.3;
    animation: hb 1.6s infinite;
  }
  .viz-pulse s:nth-child(2) { animation-delay: 0.2s; }
  .viz-pulse s:nth-child(3) { animation-delay: 0.4s; }
  .viz-pulse s:nth-child(4) { animation-delay: 0.6s; }
  .viz-pulse s:nth-child(5) { animation-delay: 0.8s; }
  .viz-pulse em {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--faint);
    font-style: normal;
  }
  @keyframes hb {
    0%, 100% { opacity: 0.25; transform: scale(1); }
    40% { opacity: 1; transform: scale(1.5); box-shadow: 0 0 10px var(--glow-lime); }
  }

  .beat__viz--chips {
    grid-auto-flow: row;
    align-content: center;
    gap: 0.7rem;
  }
  .chip {
    justify-self: start;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.55em 0.9em;
    border-radius: 999px;
    border: 1px solid var(--line);
    color: var(--muted);
  }
  .chip--on {
    border-color: transparent;
    background: var(--signal);
    color: #0a0612;
    font-weight: 600;
  }
  .chip--drag { color: var(--faint); border-style: dashed; }

  .claim {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-size: 0.95rem;
    padding: 0.7rem 0.9rem;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--line);
  }
  .claim em { margin-left: auto; font-style: normal; color: var(--lime); font-family: var(--font-mono); font-size: 0.78rem; }
  .claim--pending { opacity: 0.6; }
  .claim--pending span { width: 7px; height: 7px; border-radius: 50%; border: 1px solid var(--faint); }
  .claim--pending em { color: var(--faint); }

  .logline {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--muted);
    padding: 0.55rem 0.7rem;
    border-radius: 9px;
    background: var(--void);
    border: 1px solid var(--line);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .logline i { color: var(--faint); margin-right: 0.6rem; font-style: normal; }
  .logline b { color: var(--purple-soft); margin-right: 0.6rem; font-weight: 600; }
  .logline b.ok { color: var(--lime); }

  /* "and more" row */
  .feat__more {
    list-style: none;
    padding: 0;
    margin: clamp(4rem, 9vw, 7rem) 0 0;
    display: grid;
    gap: 1.4rem 2.5rem;
    border-top: 1px solid var(--line);
    padding-top: clamp(2rem, 4vw, 3rem);
  }
  @media (min-width: 720px) {
    .feat__more {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .feat__more strong {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    margin-bottom: 0.3rem;
  }
  .feat__more span {
    color: var(--muted);
    font-size: 0.92rem;
  }
</style>
