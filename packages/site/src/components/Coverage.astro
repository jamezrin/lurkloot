---
// Coverage = platforms + games in one act: what it farms (Twitch & Kick cards)
// and the proof (revolving 3D wall of box art). Merges the old Platforms and
// Games sections, which repeated each other's copy.
import { Image } from "astro:assets";

const platforms = [
  {
    key: "twitch",
    name: "Twitch",
    blurb:
      "It finds the Twitch drops you can earn, keeps you on a channel that's actually dropping them, and claims every reward for you — channel points included.",
    points: ["Finds every drop you can earn", "Always on a dropping channel", "Claims drops + channel points"],
  },
  {
    key: "kick",
    name: "Kick",
    blurb:
      "Full Kick drops support, right in your browser. It follows live campaigns, picks the right channel for the reward you want, and claims it the moment it unlocks.",
    points: ["Follows live Kick campaigns", "Picks the right channel for you", "Claims rewards automatically"],
  },
];

// Eagerly import every game cover (Twitch box art) so Astro fingerprints +
// optimizes them.
const covers = import.meta.glob<{ default: ImageMetadata }>("../assets/games/*.jpg", { eager: true });

const NAMES: Record<string, string> = {
  rust: "Rust",
  valorant: "Valorant",
  "apex-legends": "Apex Legends",
  "dota-2": "Dota 2",
  "counter-strike": "Counter-Strike 2",
  "escape-from-tarkov": "Escape from Tarkov",
  "rainbow-six-siege": "Rainbow Six Siege",
  "dead-by-daylight": "Dead by Daylight",
  warframe: "Warframe",
  "league-of-legends": "League of Legends",
  "new-world": "New World",
  "destiny-2": "Destiny 2",
  "sea-of-thieves": "Sea of Thieves",
  "halo-infinite": "Halo Infinite",
  "diablo-iv": "Diablo IV",
  pubg: "PUBG",
  "war-thunder": "War Thunder",
};

type Game = { name: string; img: ImageMetadata };
const games: Game[] = Object.entries(covers)
  .map(([path, mod]) => {
    const slug = path.split("/").pop()!.replace(".jpg", "");
    return { name: NAMES[slug] ?? slug, img: mod.default };
  })
  .sort((a, b) => a.name.localeCompare(b.name));

// Split into two rows that scroll in opposite directions. Each row is doubled
// so the CSS marquee loops seamlessly. (Mobile / reduced-motion fallback — on
// desktop the covers form a revolving 3D carousel instead.)
const mid = Math.ceil(games.length / 2);
const rowA: Game[] = games.slice(0, mid);
const rowB: Game[] = games.slice(mid);
const loopA = [...rowA, ...rowA];
const loopB = [...rowB, ...rowB];

// 3D ring geometry: place every cover on a cylinder. Radius derives from the
// card width + breathing room so neighbours never overlap.
const RING_STEP = 360 / games.length;
const RING_RADIUS = Math.round((games.length * 196) / (2 * Math.PI));
---

<section id="coverage" class="cov act">
  <div class="wrap">
    <div class="cov__head">
      <p class="eyebrow reveal">Coverage</p>
      <h2 class="reveal-slow">Two platforms.<br />Every drop campaign.</h2>
      <p class="reveal">
        Farming <b>Rust</b> Twitch drops, <b>Valorant</b> rewards, or a Kick partner
        campaign — it speaks both platforms natively, no manual channel hunting.
      </p>
    </div>

    <div class="cov__grid">
      {platforms.map((p) => (
        <div class="reveal">
        <article class={`cov__card cov__card--${p.key}`} data-tilt="" data-tilt-max="5">
          <div class="cov__top">
            <span class={`cov__badge cov__badge--${p.key}`}>{p.name[0]}</span>
            <h3>{p.name}</h3>
            <span class="cov__status"><span class="dot"></span> supported</span>
          </div>
          <p>{p.blurb}</p>
          <ul>
            {p.points.map((pt) => <li>{pt}</li>)}
          </ul>
        </article>
        </div>
      ))}
    </div>
  </div>

  <div class="wrap">
    <p class="cov__games-lede reveal">
      <span class="grad-text">Any game, any campaign.</span> If a drop exists,
      it gets farmed the moment it goes live — these are just a few of them.
    </p>
  </div>

  <!-- Desktop: a revolving 3D carousel of box art. -->
  <div class="ring-scene" style={`--ring-r:${RING_RADIUS}px`}>
    <div class="ring-tilt">
      <div class="ring3d">
        {games.map((g, i) => (
          <figure class="gcard gcard--ring" style={`--ra:${(i * RING_STEP).toFixed(2)}deg`}>
            <Image src={g.img} alt={`${g.name} — Twitch drops supported`} widths={[180, 320]} sizes="180px" loading="lazy" />
            <figcaption>{g.name}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </div>

  <div class="marq">
    <div class="marq__track">
      {loopA.map((g) => (
        <figure class="gcard">
          <Image src={g.img} alt={`${g.name} — Twitch drops supported`} widths={[150, 260]} sizes="150px" loading="lazy" />
          <figcaption>{g.name}</figcaption>
        </figure>
      ))}
    </div>
  </div>
  <div class="marq marq--rev">
    <div class="marq__track">
      {loopB.map((g) => (
        <figure class="gcard">
          <Image src={g.img} alt={`${g.name} — Twitch drops supported`} widths={[150, 260]} sizes="150px" loading="lazy" />
          <figcaption>{g.name}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .cov {
    overflow: hidden;
  }
  .cov__head h2 {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.98;
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    margin: 0.6rem 0 1rem;
  }
  .cov__head > p:last-child {
    color: var(--muted);
    font-size: 1.1rem;
    max-width: 52ch;
  }
  .cov__head b { color: var(--text); font-weight: 600; }

  /* ---------- platform cards ---------- */
  .cov__grid {
    display: grid;
    gap: 1.2rem;
    margin-top: clamp(2.5rem, 6vw, 4rem);
  }
  @media (min-width: 760px) {
    .cov__grid { grid-template-columns: 1fr 1fr; }
  }
  .cov__card {
    height: 100%;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    padding: clamp(1.8rem, 3vw, 2.6rem);
    transition: transform 0.4s var(--ease), border-color 0.4s var(--ease);
  }
  .cov__card--twitch {
    background: radial-gradient(120% 130% at 0% 0%, rgba(145, 71, 255, 0.22), transparent 55%), var(--ink-0);
  }
  .cov__card--twitch:hover { border-color: rgba(145, 71, 255, 0.55); }
  .cov__card--kick {
    background: radial-gradient(120% 130% at 100% 0%, rgba(83, 252, 24, 0.16), transparent 55%), var(--ink-0);
  }
  .cov__card--kick:hover { border-color: rgba(83, 252, 24, 0.5); }

  .cov__top {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1.2rem;
  }
  .cov__badge {
    width: 46px;
    height: 46px;
    border-radius: 13px;
    display: grid;
    place-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.4rem;
  }
  .cov__badge--twitch { background: linear-gradient(135deg, #a06bff, #7c3aed); color: #fff; }
  .cov__badge--kick { background: linear-gradient(135deg, #7bfd49, #3fbf12); color: #07140a; }
  .cov__top h3 {
    flex: 1;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.7rem;
    letter-spacing: -0.02em;
  }
  .cov__status {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--muted);
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
  }
  .cov__card > p {
    color: var(--muted);
    font-size: 1.02rem;
  }
  .cov__card ul {
    list-style: none;
    padding: 0;
    margin: 1.3rem 0 0;
    display: grid;
    gap: 0.5rem;
  }
  .cov__card li {
    position: relative;
    padding-left: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text);
  }
  .cov__card li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--purple-soft);
  }

  /* ---------- games lede ---------- */
  .cov__games-lede {
    text-align: center;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.2rem, 2.4vw, 1.7rem);
    letter-spacing: -0.02em;
    max-width: 44ch;
    margin: clamp(4rem, 9vw, 6.5rem) auto clamp(1.5rem, 3vw, 2.5rem);
  }

  /* ---------- 3D ring carousel (desktop, motion-friendly only) ---------- */
  .ring-scene {
    display: none;
  }
  @media (min-width: 900px) and (prefers-reduced-motion: no-preference) {
    .marq {
      display: none;
    }
    .ring-scene {
      display: block;
      perspective: 1800px;
      /* tall enough that the nearest cards — scaled up by perspective AND
         pushed down ~85px by the rotateX tilt — aren't masked off */
      height: 580px;
      margin-top: -2rem;
      -webkit-mask-image: linear-gradient(90deg, transparent, #000 14%, #000 86%, transparent);
      mask-image: linear-gradient(90deg, transparent, #000 14%, #000 86%, transparent);
    }
    .ring-tilt {
      height: 100%;
      transform-style: preserve-3d;
      transform: rotateX(-9deg);
    }
    .ring3d {
      position: relative;
      height: 100%;
      transform-style: preserve-3d;
      animation: ring-spin 75s linear infinite;
    }
    .ring-scene:hover .ring3d {
      animation-play-state: paused;
    }
    @keyframes ring-spin {
      to {
        transform: rotateY(-360deg);
      }
    }
    /* .gcard.gcard--ring outranks the base .gcard rules further down */
    .gcard.gcard--ring {
      position: absolute;
      left: calc(50% - 85px);
      /* biased above center: the tilt drops the near (largest) cards lower */
      top: calc(50% - 145px);
      width: 170px;
      height: 226px;
      transform: rotateY(var(--ra)) translateZ(var(--ring-r));
      backface-visibility: hidden;
      transition: border-color 0.35s var(--ease), box-shadow 0.35s var(--ease);
    }
    /* placement transform is load-bearing — pop with light, not movement */
    .gcard.gcard--ring:hover {
      transform: rotateY(var(--ra)) translateZ(var(--ring-r));
      border-color: var(--purple);
      box-shadow: 0 30px 60px -28px var(--glow-purple);
    }
  }

  /* ---------- marquee fallback ---------- */
  .marq {
    overflow: hidden;
    padding: 0.6rem 0;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
  }
  .marq__track {
    display: flex;
    gap: 1rem;
    width: max-content;
    animation: scroll-l 58s linear infinite;
  }
  .marq--rev .marq__track {
    animation-direction: reverse;
    animation-duration: 66s;
  }
  .marq:hover .marq__track {
    animation-play-state: paused;
  }
  @keyframes scroll-l {
    to {
      transform: translateX(-50%);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .marq__track {
      animation: none;
    }
  }

  .gcard {
    position: relative;
    flex: 0 0 auto;
    width: clamp(116px, 13vw, 150px);
    aspect-ratio: 3 / 4;
    margin: 0;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--ink-2);
    box-shadow: 0 18px 40px -24px rgba(0, 0, 0, 0.9);
    transition: transform 0.35s var(--ease), border-color 0.35s var(--ease), box-shadow 0.35s var(--ease);
  }
  .gcard :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(1.05) contrast(1.02);
    transition: transform 0.5s var(--ease);
  }
  .gcard::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 45%, rgba(6, 6, 9, 0.92));
    opacity: 0.85;
    transition: opacity 0.35s var(--ease);
  }
  .gcard figcaption {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    z-index: 1;
    padding: 0.7rem 0.7rem 0.6rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.82rem;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: #fff;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.7);
  }
  .gcard:hover {
    transform: translateY(-8px) scale(1.04);
    border-color: var(--purple);
    box-shadow: 0 30px 60px -28px var(--glow-purple);
  }
  .gcard:hover :global(img) {
    transform: scale(1.08);
  }
  .gcard:hover::after {
    opacity: 1;
  }
</style>
