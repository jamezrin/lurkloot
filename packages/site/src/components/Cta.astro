---
import { LINKS } from "../consts";
import BrowserPills from "./BrowserPills.astro";
---

<section class="cta act">
  <div class="wrap cta__inner reveal-slow">
    <div class="cta__glow" aria-hidden="true"></div>
    <p class="eyebrow">Ready when you are</p>
    <h2>Stop watching.<br />Start <span class="grad-text">collecting</span>.</h2>
    <p class="cta__lede">
      Free, and running in under a minute. Install once and let your drops pile up while
      you do literally anything else.
    </p>
    <div class="cta__btns">
      <a class="btn btn--primary btn--lg" href={LINKS.chrome} target="_blank" rel="noopener">
        Add to your browser — free
      </a>
    </div>
    <div class="cta__pills"><BrowserPills /></div>
    <ul class="cta__assure">
      <li>No .exe, no download — just an extension</li>
      <li>Vetted by the Chrome Web Store review</li>
      <li>Windows · macOS · Linux · ChromeOS</li>
      <li>Updated for every Twitch &amp; Kick change</li>
    </ul>
    <p class="cta__fine">No account · No password · No tracking</p>
  </div>
</section>

<style>
  .cta__inner {
    position: relative;
    text-align: center;
    border: 1px solid var(--line-strong);
    border-radius: 32px;
    padding: clamp(3rem, 8vw, 6rem) clamp(1.5rem, 5vw, 4rem);
    background: linear-gradient(180deg, var(--ink-2), var(--ink-0));
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .cta__glow {
    position: absolute;
    inset: -50% 10% auto;
    height: 70%;
    background: radial-gradient(closest-side, rgba(145, 71, 255, 0.4), transparent);
    filter: blur(40px);
    pointer-events: none;
  }
  .cta h2 {
    position: relative;
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.96;
    font-size: clamp(2.6rem, 7vw, 5rem);
    margin: 0.8rem 0 0;
  }
  .cta__lede {
    position: relative;
    color: var(--muted);
    font-size: 1.12rem;
    max-width: 46ch;
    margin: 1.4rem auto 0;
  }
  .cta__btns {
    position: relative;
    margin-top: 2.2rem;
  }
  .cta__pills {
    position: relative;
    margin-top: 1.8rem;
  }
  /* compact objection-buster strip (replaces the old Assurance section) */
  .cta__assure {
    position: relative;
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
  }
  .cta__assure li {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.02em;
    color: var(--muted);
    padding: 0.45em 0.9em;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.02);
  }
  .cta__assure li::before {
    content: "✓";
    font-weight: 700;
    background: var(--signal-text);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .cta__fine {
    position: relative;
    margin-top: 1.6rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.06em;
    color: var(--faint);
  }
</style>
