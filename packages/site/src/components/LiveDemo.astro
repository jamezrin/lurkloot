---
import PopupDemo from "../popup-ui/PopupDemo.tsx";
---

<section id="demo" class="demo act">
  <div class="wrap">
    <div class="demo__head">
      <p class="eyebrow reveal">See it first</p>
      <h2 class="reveal-slow">This is how the<br />extension looks.</h2>
      <p class="reveal">
        An interactive — but non-functional — demo of the actual popup, running on mock
        data. Switch Twitch/Kick, open Settings, reorder campaigns, flip toggles. Nothing
        here is really farming; it's just exactly the UI you get after installing.
      </p>
    </div>

    <div class="demo__stage">
      <div class="demo__glow" aria-hidden="true"></div>
      <div class="demo__screen arrive">
        <span class="demo__pill"><span class="dot"></span> interactive demo · mock data</span>
        <PopupDemo client:visible />
      </div>
    </div>
  </div>
</section>

<style>
  .demo { overflow: clip; }
  .demo__head {
    text-align: center;
    max-width: 40ch;
    margin: 0 auto clamp(3rem, 7vw, 5rem);
  }
  .demo__head h2 {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.98;
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    margin: 0.6rem 0 1rem;
  }
  .demo__head p { color: var(--muted); font-size: 1.08rem; }

  .demo__stage {
    position: relative;
    display: flex;
    justify-content: center;
  }
  .demo__glow {
    position: absolute;
    top: -12%;
    width: min(720px, 92%);
    height: 80%;
    background: radial-gradient(closest-side, rgba(124, 58, 237, 0.38), transparent 70%);
    filter: blur(50px);
    pointer-events: none;
  }
  .demo__screen {
    position: relative;
    width: 400px;
    min-height: 600px;
  }
  .demo__screen :global(.sa-popup-host) {
    display: block;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 60px 110px -50px rgba(0, 0, 0, 0.95), 0 0 0 1px rgba(255, 255, 255, 0.04);
  }
  .demo__pill {
    position: absolute;
    top: -1.3rem;
    right: 0.4rem;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    padding: 0.42em 0.75em;
    border-radius: 999px;
    border: 1px solid var(--line-strong);
    background: var(--ink-2);
    color: var(--muted);
  }
  @media (max-width: 460px) {
    .demo__stage { height: calc(600px * 0.82 + 1.5rem); }
    .demo__screen { transform: scale(0.82); transform-origin: top center; }
  }
</style>
