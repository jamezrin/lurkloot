---
// Compact reassurance band right before the final CTA — busts install-time
// objections (legit, safe, universal, maintained) without repeating the
// data-privacy or browser-logo messaging elsewhere on the page.
const points = [
  {
    t: "No shady downloads",
    d: "It's a browser extension, not a desktop app — no .exe to run, no Windows security warning, no admin prompts.",
  },
  {
    t: "Vetted by Google",
    d: "Published on the Chrome Web Store and cleared by Google's security and privacy review.",
  },
  {
    t: "Runs on any setup",
    d: "Windows, macOS, Linux or ChromeOS, on any Chromium browser. One extension, every machine.",
  },
  {
    t: "Always up to date",
    d: "Updated often with new features and quick support for every Twitch and Kick change.",
  },
];
---

<section class="assure act">
  <div class="wrap">
    <div class="assure__head">
      <p class="eyebrow reveal">Peace of mind</p>
      <h2 class="reveal-slow">Installs clean.<br />Stays clean.</h2>
    </div>
    <ul class="assure__list">
      {points.map((p) => (
        <li class="reveal">
          <span class="assure__mark">✓</span>
          <div>
            <strong>{p.t}</strong>
            <p>{p.d}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .assure__head {
    text-align: center;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .assure__head h2 {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.98;
    font-size: clamp(1.9rem, 4.5vw, 3rem);
    margin-top: 0.6rem;
  }
  .assure__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
  }
  @media (min-width: 520px) {
    .assure__list { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 920px) {
    .assure__list { grid-template-columns: repeat(4, 1fr); }
  }
  .assure__list li {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding: 1.5rem;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: linear-gradient(180deg, var(--ink-1), var(--ink-0));
  }
  .assure__mark {
    flex: 0 0 auto;
    width: 28px;
    height: 28px;
    border-radius: 9px;
    display: grid;
    place-content: center;
    font-size: 0.9rem;
    font-weight: 700;
    color: #0a0612;
    background: var(--signal);
  }
  .assure__list strong {
    display: block;
    font-family: var(--font-display);
    font-size: 1.1rem;
    margin-bottom: 0.3rem;
  }
  .assure__list p {
    color: var(--muted);
    font-size: 0.92rem;
  }
</style>
